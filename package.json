{
  "name": "sistema-gestion-cc",
  "version": "1.0.0",
  "type": "module",
  "main": "src/main/main.js",
  "scripts": {
    "start": "cross-env NODE_ENV=development electron .",
    "dev": "concurrently \"npm run start-react\" \"wait-on http://localhost:3000 && npm start\"",
    "start-react": "cross-env BROWSER=none react-scripts start",
    "build": "react-scripts build",
    "electron-build": "npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "better-sqlite3": "^9.0.0",
    "electron": "^28.0.0",
    "@supabase/supabase-js": "^2.39.0",
    "pg": "^8.11.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
